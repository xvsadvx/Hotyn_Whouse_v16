DATA_BLOCK "DB_Test_IO"
{ S7_Optimized_Access := 'FALSE' }
VERSION : 0.1
   STRUCT 
      Sim_Enable_Saw : Bool;
      Sim_Enable_Noise : Bool;
      Sim_Saw_Speed : Real;
      Sim_Noise_Amp : Int;
      Sim_Noise_Hz : Real;
      Raw_Final : Int;
      Reset_Alarms : Bool;
      Config : Array[1..2] of "UDT_AI_Config";
      Out : Array[1..2] of "UDT_AI_Out";
      Alarm_Cfg : Array[1..2] of "UDT_Alarm_Config";
      Alarm_Out : Array[1..2] of "UDT_Alarm_Out";
      Raw_Start { S7_SetPoint := 'True'} : Int;
   END_STRUCT;


BEGIN
   Sim_Saw_Speed := 500.0;
   Sim_Noise_Amp := 200;
   Sim_Noise_Hz := 2.0;
   Config[1].Scale_Max := 100.0;
   Alarm_Cfg[1].HiHi := 90.0;
   Alarm_Cfg[1].Delay_HiHi := 2;

END_DATA_BLOCK

