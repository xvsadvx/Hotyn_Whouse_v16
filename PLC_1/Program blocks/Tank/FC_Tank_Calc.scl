FUNCTION "FC_Tank_Calc" : Void
TITLE = Tank Physics Calculator
{ S7_Optimized_Access := 'FALSE' }
AUTHOR : Gemini
FAMILY : Archive
VERSION : 1.2
// ==============================================================================
// Описание: Расчет физических показателей танка (Цилиндр).
//           Поддерживает режим весов (кг) и режим уровня (м).
// ==============================================================================
   VAR_INPUT 
      i_rValue : Real;   // Входящее значение (м или кг)
      i_boIsSiwa : Bool;   // TRUE = Весы (кг), FALSE = Уровень (м)
   END_VAR

   VAR_IN_OUT 
      io_Geom : "UDT_Tank_Geom";
      iq_Calc : "UDT_Tank_Calc";
   END_VAR

   VAR_TEMP 
      temp_rPI : Real;
      temp_rArea : Real;
      temp_rDensity : Real;
   END_VAR


BEGIN
	    // Константы и проверки безопасности
	    #temp_rPI := 3.141593;
	    
	    // Плотность не может быть 0 (защита от деления)
	    IF #io_Geom.Density_tm3 < 0.001 THEN
	        #temp_rDensity := 1.0;
	    ELSE
	        #temp_rDensity := #io_Geom.Density_tm3;
	    END_IF;
	    
	    // 1. Расчет площади основания (S = PI * R^2) и макс. объема
	    #temp_rArea := #temp_rPI * #io_Geom.Radius_m * #io_Geom.Radius_m;
	    #iq_Calc.Max_Volume_m3 := #temp_rArea * #io_Geom.Height_Full_m;
	    
	    // Проверка на корректность геометрии
	    IF #iq_Calc.Max_Volume_m3 < 0.01 OR #io_Geom.Height_Full_m < 0.01 THEN
	        RETURN; // Выходим, если танк "пустой" в настройках
	    END_IF;
	    
	    // 2. Основной расчет в зависимости от режима
	    IF #i_boIsSiwa THEN
	        // --- РЕЖИМ ВЕСОВ (Вход в кг) ---
	        #iq_Calc.Weight_t := #i_rValue / 1000.0;
	        #iq_Calc.Volume_m3 := #iq_Calc.Weight_t / #temp_rDensity; // V(м3) = m(т) / rho(т/м3) 
	        
	        // Уровень вычисляем обратно из объема
	        #iq_Calc.Level_m := #iq_Calc.Volume_m3 / #temp_rArea;
	    ELSE
	        // --- РЕЖИМ УРОВНЯ (Вход в м) ---
	        #iq_Calc.Level_m := #i_rValue + #io_Geom.Sensor_Offset_m;
	        #iq_Calc.Volume_m3 := #iq_Calc.Level_m * #temp_rArea;
	        
	        // Вес вычисляем из объема
	        #iq_Calc.Weight_t := #iq_Calc.Volume_m3 * #temp_rDensity; // m(т) = V(м3) * rho(т/м3)
	    END_IF;
	    
	    // 3. Расчет процентов
	    #iq_Calc.Level_Pct := (#iq_Calc.Level_m / #io_Geom.Height_Full_m) * 100.0;
	    #iq_Calc.Volume_Pct := (#iq_Calc.Volume_m3 / #iq_Calc.Max_Volume_m3) * 100.0;
END_FUNCTION

