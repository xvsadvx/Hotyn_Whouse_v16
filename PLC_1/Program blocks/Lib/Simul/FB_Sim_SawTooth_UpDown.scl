FUNCTION_BLOCK "FB_Sim_SawTooth_UpDown"
{ S7_Optimized_Access := 'FALSE' }
VERSION : 0.1
   VAR_INPUT 
      Enable : Bool;
      Speed : Real;
      Limit_High : Int := 27648;   // Верхний предел (по умолчанию максимум для аналогового входа Siemens)
      Limit_Low : Int := 0;   // Нижний предел
   END_VAR

   VAR_OUTPUT 
      Out_Raw : Int;
   END_VAR

   VAR_IN_OUT 
      Current_Val : Int;
   END_VAR

   VAR 
      Dir_Up : Bool := TRUE;   // Направление: TRUE = вверх, FALSE = вниз
   END_VAR

   VAR_TEMP 
      Increment : Int;
   END_VAR


BEGIN
	    // Если блок выключен, замораживаем текущее значение, сохраняем направление и выходим
	    IF NOT #Enable THEN
	        #Out_Raw := #Current_Val;
	        RETURN;
	    END_IF;
	    
	    // Рассчитываем шаг за цикл
	    #Increment := REAL_TO_INT(ABS(#Speed) * "getCycleTime"() / 1000.0);
	    
	    // Логика треугольного сигнала ("вверх-вниз")
	    IF #Dir_Up THEN
	        // Считаем вверх
	        #Current_Val := #Current_Val + #Increment;
	        IF #Current_Val >= #Limit_High THEN
	            #Current_Val := #Limit_High;
	            #Dir_Up := FALSE; // Меняем направление на "вниз"
	        END_IF;
	    ELSE
	        // Считаем вниз
	        #Current_Val := #Current_Val - #Increment;
	        IF #Current_Val <= #Limit_Low THEN
	            #Current_Val := #Limit_Low;
	            #Dir_Up := TRUE;  // Меняем направление на "вверх"
	        END_IF;
	    END_IF;
	    
	    // Обновляем выход
	    #Out_Raw := #Current_Val;
	    
END_FUNCTION_BLOCK

