FUNCTION_BLOCK "FB_AI_Alarm"
{ S7_Optimized_Access := 'FALSE' }
VERSION : 2.0
   VAR_INPUT 
      i_rValue : Real;
      i_boReset : Bool;
      i_boInhibit : Bool;
   END_VAR

   VAR_IN_OUT 
      io_stConfig : "UDT_AI_Alarm_Conf";
      io_stOut : "UDT_AI_Alarm";
   END_VAR

   VAR 
      stat_TonHiHi {InstructionName := 'TON'; LibVersion := '1.0'; S7_SetPoint := 'False'} : TON;
      stat_TonHi {InstructionName := 'TON'; LibVersion := '1.0'; S7_SetPoint := 'False'} : TON;
      stat_TonLo {InstructionName := 'TON'; LibVersion := '1.0'; S7_SetPoint := 'False'} : TON;
      stat_TonLoLo {InstructionName := 'TON'; LibVersion := '1.0'; S7_SetPoint := 'False'} : TON;
      stat_RawHiHi : Bool;
      stat_RawHi : Bool;
      stat_RawLo : Bool;
      stat_RawLoLo : Bool;
   END_VAR


BEGIN
	    // =========================================================
	    // 0. ЗАЩИТА ОТ ДУРАКА (Ограничение уставок времени >= 0)
	    // =========================================================
	    IF #io_stConfig.Delay_HiHi < 0 THEN
	        #io_stConfig.Delay_HiHi := 0;
	    END_IF;
	    IF #io_stConfig.Delay_Hi < 0 THEN
	        #io_stConfig.Delay_Hi := 0;
	    END_IF;
	    IF #io_stConfig.Delay_Lo < 0 THEN
	        #io_stConfig.Delay_Lo := 0;
	    END_IF;
	    IF #io_stConfig.Delay_LoLo < 0 THEN
	        #io_stConfig.Delay_LoLo := 0;
	    END_IF;
	    
	    // =========================================================
	    // 1. ТРАНСЛЯЦИЯ СТАТУСОВ ДЛЯ HMI (En_Out)
	    // =========================================================
	    #io_stOut.En_HiHi := #io_stConfig.En_Alarm.HiHi AND NOT #i_boInhibit;
	    #io_stOut.En_Hi := #io_stConfig.En_Alarm.Hi AND NOT #i_boInhibit;
	    #io_stOut.En_Lo := #io_stConfig.En_Alarm.Lo AND NOT #i_boInhibit;
	    #io_stOut.En_LoLo := #io_stConfig.En_Alarm.LoLo AND NOT #i_boInhibit;
	    #io_stOut.En_Latch_Enable := #io_stConfig.En_Alarm.Latch_Enable;
	    
	    // =========================================================
	    // 2. ОБРАБОТКА СЫРЫХ АВАРИЙ С ГИСТЕРЕЗИСОМ (Deadband)
	    // =========================================================
	    // Верхние пороги (Срабатывание >, Сброс <)
	    IF #i_rValue > #io_stConfig.HiHi THEN
	        #stat_RawHiHi := TRUE;
	    ELSIF #i_rValue < (#io_stConfig.HiHi - #io_stConfig.Hysteresis) THEN
	        #stat_RawHiHi := FALSE;
	    END_IF;
	    
	    IF #i_rValue > #io_stConfig.Hi THEN
	        #stat_RawHi := TRUE;
	    ELSIF #i_rValue < (#io_stConfig.Hi - #io_stConfig.Hysteresis) THEN
	        #stat_RawHi := FALSE;
	    END_IF;
	    
	    // Нижние пороги (Срабатывание <, Сброс >)
	    IF #i_rValue < #io_stConfig.Lo THEN
	        #stat_RawLo := TRUE;
	    ELSIF #i_rValue > (#io_stConfig.Lo + #io_stConfig.Hysteresis) THEN
	        #stat_RawLo := FALSE;
	    END_IF;
	    
	    IF #i_rValue < #io_stConfig.LoLo THEN
	        #stat_RawLoLo := TRUE;
	    ELSIF #i_rValue > (#io_stConfig.LoLo + #io_stConfig.Hysteresis) THEN
	        #stat_RawLoLo := FALSE;
	    END_IF;
	    
	    // =========================================================
	    // 3. ТАЙМЕРЫ ЗАДЕРЖКИ (ON-Delay)
	    // =========================================================
	    // Таймер не считает, если сработала блокировка датчика (Inhibit) 
	    // или аларм выключен в настройках.
	    #stat_TonHiHi(IN := #stat_RawHiHi AND #io_stConfig.En_Alarm.HiHi AND NOT #i_boInhibit,
	                  PT := DINT_TO_TIME(#io_stConfig.Delay_HiHi) * 1000 + t#1ms);//gr-ny 300
	    
	    #stat_TonHi(IN := #stat_RawHi AND #io_stConfig.En_Alarm.Hi AND NOT #i_boInhibit,
	                PT := DINT_TO_TIME(#io_stConfig.Delay_Hi) * 1000 + t#1ms);//gr-ny 300
	    
	    #stat_TonLo(IN := #stat_RawLo AND #io_stConfig.En_Alarm.Lo AND NOT #i_boInhibit,
	                PT := DINT_TO_TIME(#io_stConfig.Delay_Lo) * 1000 + t#1ms);//gr-ny 300
	    
	    #stat_TonLoLo(IN := #stat_RawLoLo AND #io_stConfig.En_Alarm.LoLo AND NOT #i_boInhibit,
	                  PT := DINT_TO_TIME(#io_stConfig.Delay_LoLo) * 1000 + t#1ms);//gr-ny 300
	    
	    // =========================================================
	    // 4. ФИКСАЦИЯ (LATCH) И СБРОС АВАРИЙ
	    // =========================================================
	    // Логика сброса (имеет приоритет):
	    // 1. Сработал Inhibit (глушим всё безусловно)
	    // 2. Аларм сняли в настройках
	    // 3. Уровень в норме И (нет фиксации ИЛИ нажата кнопка Reset)
	    
	    // --- HiHi ---
	    IF #i_boInhibit OR NOT #io_stConfig.En_Alarm.HiHi OR
	        (NOT #stat_RawHiHi AND (NOT #io_stConfig.En_Alarm.Latch_Enable OR #i_boReset)) THEN
	        #io_stOut.HiHi := FALSE;
	    ELSIF #stat_TonHiHi.Q THEN
	        #io_stOut.HiHi := TRUE;
	    END_IF;
	    
	    // --- Hi ---
	    IF #i_boInhibit OR NOT #io_stConfig.En_Alarm.Hi OR
	        (NOT #stat_RawHi AND (NOT #io_stConfig.En_Alarm.Latch_Enable OR #i_boReset)) THEN
	        #io_stOut.Hi := FALSE;
	    ELSIF #stat_TonHi.Q THEN
	        #io_stOut.Hi := TRUE;
	    END_IF;
	    
	    // --- Lo ---
	    IF #i_boInhibit OR NOT #io_stConfig.En_Alarm.Lo OR
	        (NOT #stat_RawLo AND (NOT #io_stConfig.En_Alarm.Latch_Enable OR #i_boReset)) THEN
	        #io_stOut.Lo := FALSE;
	    ELSIF #stat_TonLo.Q THEN
	        #io_stOut.Lo := TRUE;
	    END_IF;
	    
	    // --- LoLo ---
	    IF #i_boInhibit OR NOT #io_stConfig.En_Alarm.LoLo OR
	        (NOT #stat_RawLoLo AND (NOT #io_stConfig.En_Alarm.Latch_Enable OR #i_boReset)) THEN
	        #io_stOut.LoLo := FALSE;
	    ELSIF #stat_TonLoLo.Q THEN
	        #io_stOut.LoLo := TRUE;
	    END_IF;
	    
END_FUNCTION_BLOCK

