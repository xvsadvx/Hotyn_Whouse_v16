DATA_BLOCK "DB_DateTime"
{ S7_Optimized_Access := 'FALSE' }
VERSION : 0.1
NON_RETAIN
   STRUCT 
      TimeOfDay_PLC : Time_Of_Day;
      Date_PLC : Date;
      DateTime_PLC : Date_And_Time;
      stReadDataTime_PLC : Int;
      DT_Byte : Array[0..7] of Byte;
      isNewHour : Bool;
      isNewShift : Bool;
   END_STRUCT;


BEGIN
   TimeOfDay_PLC := TOD#16:14:12.371;
   Date_PLC := D#2021-11-15;
   DateTime_PLC := DT#2021-11-15-16:14:12.374;

END_DATA_BLOCK

